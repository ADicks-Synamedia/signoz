# =============================================================================
# SigNoz Entra ID SSO Configuration
# =============================================================================
# Copy this file to .env and fill in your Azure Entra ID values.
# Then run: docker compose -f docker-compose.yaml -f docker-compose-entra-sso.yaml up -d
# =============================================================================

# --- Base SigNoz Docker Compose Configuration ---

# Docker Compose project name (controls container/volume/network prefixes)
# Without this, Compose derives the project name from the working directory,
# which breaks documentation referencing container names like signoz-signoz-1.
COMPOSE_PROJECT_NAME=signoz

# --- Required for SSO-First Deployments ---
# These create the first organization and a break-glass admin user the moment
# the server starts. SigNoz needs an organization to exist before SSO can be
# configured (collectors are rejected without one), and you need a non-SSO
# admin in case Entra is misconfigured or unreachable.

# Master switch for the root user reconciler — must be "true" for SSO-first deployments
SIGNOZ_USER_ROOT_ENABLED=true

# Email address for the bootstrap admin user (also used to log in as a fallback)
SIGNOZ_USER_ROOT_EMAIL=admin@corp.com

# Password for the bootstrap admin user
# Must meet password requirements (length, complexity); see pkg/types password validation
SIGNOZ_USER_ROOT_PASSWORD=replace-with-a-strong-password

# Display name for the bootstrap organization (defaults to "default" if unset)
SIGNOZ_USER_ROOT_ORG_NAME=default

# --- Required Variables ---

# Master switch to enable Entra SSO (set to "true" to enable)
SIGNOZ_ENTRA_SSO_ENABLED=true

# Azure Entra tenant ID (GUID) — find in Azure Portal > Entra ID > Overview
SIGNOZ_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000

# App registration client ID (GUID) — find in Azure Portal > App Registrations > your app > Overview
SIGNOZ_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# App registration client secret — create in Azure Portal > App Registrations > Certificates & secrets
SIGNOZ_ENTRA_CLIENT_SECRET=your-client-secret-here

# Email domain for SSO (e.g., corp.com) — users with this email domain will be redirected to Entra
SIGNOZ_ENTRA_DOMAIN=corp.com

# --- Optional Variables ---

# Entra group object ID (GUID) whose members get SigNoz ADMIN role
# Find in Azure Portal > Entra ID > Groups > your group > Object Id
# SIGNOZ_ENTRA_ADMIN_GROUP_ID=00000000-0000-0000-0000-000000000000

# Entra group object ID (GUID) whose members get SigNoz EDITOR role
# SIGNOZ_ENTRA_EDITOR_GROUP_ID=00000000-0000-0000-0000-000000000000

# Default SigNoz role when no group mapping matches (default: VIEWER)
# Valid values: ADMIN, EDITOR, VIEWER
# SIGNOZ_ENTRA_DEFAULT_ROLE=VIEWER

# --- Entra App Registration Setup ---
# 1. Azure Portal > App Registrations > New registration
#    - Redirect URI: https://<signoz-host>:8080/api/v1/complete/oidc
#    - Supported account types: Single tenant
# 2. Certificates & secrets > New client secret > copy to SIGNOZ_ENTRA_CLIENT_SECRET
# 3. Token configuration > Add groups claim > Security groups
# 4. Enterprise Applications > Users and groups > Assign users/groups
